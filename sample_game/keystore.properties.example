# Copy to keystore.properties (gitignored) and fill in with your signing config.
# Used by build_android.ps1 -Release to sign release APKs.
#
# One-time setup:
#   keytool -genkeypair -v -keystore release.keystore \
#           -alias release -keyalg RSA -keysize 2048 -validity 10000
# Paths below are relative to this file (the game project directory).
# Back up the keystore file — the Play Store binds your applicationId to its
# signature forever.

storeFile=release.keystore
storePassword=CHANGEME
keyAlias=release
keyPassword=CHANGEME
