{
  "preset": "rts",

  "composites": {
    "action_bar": {
      "anchor": "bc", "x": 0, "y": -16, "w": 320, "h": 58,

      "style": "classic_rts",
      "style_params": {
        "bg":                  "#14162088",
        "cooldown_overlay":    "#000000C0",
        "cooldown_text_color": "#FFFFFFFF",
        "cooldown_text_size":  20,
        "hotkey_color":        "#F0F0F0FF",
        "disabled_tint":       "#00000080"
      },
      "slot_style": {
        "bg":           "#303448F0",
        "hover_bg":     "#484C60FA",
        "press_bg":     "#666A84FF",
        "disabled_bg":  "#1E2028F0",
        "border_color": "#00000080",
        "border_width": 1
      },

      "slots": [
        { "anchor": "tl", "x":   5, "y": 5, "w": 50, "h": 50, "hotkey": "Q" },
        { "anchor": "tl", "x":  58, "y": 5, "w": 50, "h": 50, "hotkey": "W" },
        { "anchor": "tl", "x": 111, "y": 5, "w": 50, "h": 50, "hotkey": "E" },
        { "anchor": "tl", "x": 164, "y": 5, "w": 50, "h": 50, "hotkey": "R" },
        { "anchor": "tl", "x": 217, "y": 5, "w": 50, "h": 50, "hotkey": "T" },
        { "anchor": "tl", "x": 270, "y": 5, "w": 50, "h": 50, "hotkey": "Y" }
      ]
    },

    "minimap": {
      "anchor": "br", "x": -10, "y": -10, "w": 200, "h": 200,
      "style": "classic_rts",
      "style_params": {
        "bg":              "#0C0E14E6",
        "border_color":    "#000000C8",
        "border_width":    1,
        "own_dot_color":   "#50DC5AFF",
        "enemy_dot_color": "#DC4646FF",
        "dot_size":        3
      }
    }
  },

  "world_overlays": {
    "entity_bars": {
      "z_offset": 140.0,
      "size":     { "w": 34, "h": 4 },
      "spacing":  1,
      "bars": [
        {
          "state":      "health",
          "visibility": "not_full",
          "style":      { "bg_color": "#00000080", "fill_color": "#40D040FF" }
        },
        {
          "state":      "mana",
          "visibility": "always",
          "style":      { "bg_color": "#00000080", "fill_color": "#4080FFFF" }
        }
      ]
    },

    "unit_name_label": {
      "z_offset": 170.0,
      "size":     14,
      "style":    { "color": "#FFFFFFFF", "bg_color": "#000000A0" }
    }
  },

  "nodes": [
    {
      "id":    "wave_panel",
      "type":  "panel",
      "style": { "bg": "#141620DC" },

      "children": [
        {
          "id":     "wave_label",
          "type":   "label",
          "anchor": "tl",
          "x": 10, "y": 6, "w": 260, "h": 20,
          "text":   "Wave 0 / 20",
          "style":  { "color": "#FFFFFFFF", "size": 16, "align": "center" }
        },
        {
          "id":     "wave_progress",
          "type":   "bar",
          "anchor": "tl",
          "x": 10, "y": 30, "w": 260, "h": 10,
          "fill":   0.0,
          "style":  { "bg_color": "#282C38DC", "fill_color": "#50C878F0" }
        }
      ]
    },

    {
      "id":    "test_panel",
      "type":  "panel",
      "style": { "bg": "#141620DC" },

      "children": [
        {
          "id":     "test_title",
          "type":   "label",
          "anchor": "tl",
          "x": 10, "y": 8, "w": 220, "h": 24,
          "text":   "16c-iv hud.json",
          "style":  { "color": "#DCDCE6FF", "size": 18, "align": "center" }
        },

        {
          "id":     "test_bar",
          "type":   "bar",
          "anchor": "tl",
          "x": 10, "y": 42, "w": 220, "h": 14,
          "fill":   0.5,
          "style":  { "bg_color": "#282C38DC", "fill_color": "#50C878F0" }
        },

        {
          "id":     "test_icon",
          "type":   "image",
          "anchor": "tl",
          "x": 10, "y": 66, "w": 40, "h": 40,
          "source": "shared/assets/textures/terrain/grass.ktx2"
        },

        {
          "id":     "test_button",
          "type":   "button",
          "anchor": "tl",
          "x": 10, "y": 130, "w": 220, "h": 40,

          "children": [
            {
              "id":     "test_button_label",
              "type":   "label",
              "anchor": "tl",
              "x": 0, "y": 0, "w": 220, "h": 40,
              "text":   "Click me",
              "style":  { "color": "#FFFFFFFF", "size": 16, "align": "center" }
            }
          ]
        }
      ]
    }
  ]
}
