  "world_overlays": {
    "entity_bars": {
      "z_offset": 140.0,
      "size":     { "w": 34, "h": 4 },
      "spacing":  1,
      "bars": [
        {
          "state":      "health",
          "visibility": "not_full",
          "style":      { "bg_color": "#00000080", "fill_color": "#40D040FF" }
        },
        {
          "state":      "mana",
          "visibility": "always",
          "style":      { "bg_color": "#00000080", "fill_color": "#4080FFFF" }
        }
      ]
    },

    "unit_name_label": {
      "z_offset": 170.0,
      "size":     14,
      "style":    { "color": "#FFFFFFFF", "bg_color": "#000000A0" }
    }
