{
  "preset": "action",

  "composites": {
    "action_bar": {
      "anchor": "br", "x": -16, "y": -16, "w": 240, "h": 240,

      "style": "moba",
      "binding_mode": "manual",
      "style_params": {
        "bg":                  "#00000000",
        "cooldown_overlay":    "#000000B0",
        "cooldown_text_color": "#FFFFFFFF",
        "cooldown_text_size":  18,
        "hotkey_color":        "#F0F0F0FF",
        "hotkey_badge_bg":     "#000000B4",
        "disabled_tint":       "#00000080",
        "cooldown_ring_color": "#6EDCFFEB",
        "cooldown_ring_width": 4,
        "cooldown_ring_gap":   2
      },
      "slot_style": {
        "bg":           "#303448F2",
        "hover_bg":     "#484C60FA",
        "press_bg":     "#666A84FF",
        "border_color": "#000000A0",
        "border_width": 2
      },

      "//arc": "Slot centers fan around the action_bar's bottom-right corner — the natural thumb-reach for right-handed mobile players. Fan center at (w-30, h-30) = (210, 210), radius 150, four slots evenly spread from 0° (left of corner) to 90° (above corner). Slot 1 sits closest to ground level, slot 4 closest to up.",
      "slots": [
        { "anchor": "tl", "x":  30, "y": 180, "w": 60, "h": 60, "hotkey": "1" },
        { "anchor": "tl", "x":  50, "y": 105, "w": 60, "h": 60, "hotkey": "2" },
        { "anchor": "tl", "x": 105, "y":  50, "w": 60, "h": 60, "hotkey": "3" },
        { "anchor": "tl", "x": 180, "y":  30, "w": 60, "h": 60, "hotkey": "4" }
      ]
    },

    "minimap": {
      "anchor": "tl", "x": 10, "y": 10, "w": 160, "h": 160,
      "style": "classic_rts",
      "style_params": {
        "bg":              "#0C0E14E6",
        "border_color":    "#000000C8",
        "border_width":    1,
        "own_dot_color":   "#50DC5AFF",
        "enemy_dot_color": "#DC4646FF",
        "dot_size":        3
      }
    },

    "joystick": {
      "anchor": "bl", "x": 20, "y": -20, "w": 140, "h": 140,
      "style_params": {
        "base_color":        "#141620A0",
        "base_border":       "#000000C8",
        "base_border_width": 2,
        "knob_color":        "#C8CEE0DC",
        "knob_border":       "#000000C8",
        "knob_border_width": 2,
        "knob_size_frac":    0.5,
        "deadzone_frac":     0.12
      }
    }
  },

  "targeting": {
    "selection_texture": "textures/overlays/ring_stroke.ktx2",
    "range_ring":   { "texture": "textures/overlays/ring_stroke.ktx2" },
    "cast_curve":   { "texture": "textures/overlays/curve_stroke.ktx2" },
    "snap_target":  { "texture": "textures/overlays/snap_target.ktx2" },
    "aoe": {
      "circle_texture": "textures/overlays/aoe_circle.ktx2"
    }
  },

  "world_overlays": {
    "entity_bars": {
      "z_offset": 140.0,
      "size":     { "w": 34, "h": 4 },
      "spacing":  1,
      "bars": [
        {
          "state":      "health",
          "visibility": "not_full",
          "style":      { "bg_color": "#00000080", "fill_color": "#40D040FF" }
        },
        {
          "state":      "mana",
          "visibility": "always",
          "style":      { "bg_color": "#00000080", "fill_color": "#4080FFFF" }
        }
      ]
    }
  },

  "nodes": []
}
